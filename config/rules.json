{
    "rules": [
        {
            "name": "block_ssh_bruteforce",
            "protocol": "tcp",
            "destination_port": 22,
            "action": "block",
            "threshold": {
                "count": 5,
                "period": 60
            }
        },
        {
            "name": "block_rdp",
            "protocol": "tcp",
            "destination_port": 3389,
            "action": "block"
        },
        {
            "name": "limit_icmp",
            "protocol": "icmp",
            "action": "limit",
            "threshold": {
                "count": 30,
                "period": 60
            }
        }
    ],
    "thresholds": {
        "syn_flood": 100,
        "udp_flood": 500,
        "icmp_flood": 200,
        "connection_rate": 50
    },
    "whitelisted_ports": [80, 443],
    "deep_packet_inspection": true
}
